<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Comando y Control - Regimiento</title>
    <style>
        :root {
            --verde-militar: #4A5D23;
            --verde-oscuro: #2C3518;
            --gris-claro: #F4F4F4;
            --gris-oscuro: #333;
            --alerta-roja: #8B0000;
        }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; background-color: var(--gris-claro); }
        
        /* Header y Navegación */
        header { background-color: var(--verde-oscuro); color: white; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; }
        header h1 { margin: 0; font-size: 24px; }
        
        .tabs { display: flex; background-color: var(--verde-militar); overflow-x: auto; }
        .tab-btn { background: none; border: none; color: white; padding: 15px 20px; cursor: pointer; font-weight: bold; font-size: 16px; transition: 0.3s; }
        .tab-btn:hover { background-color: rgba(255,255,255,0.2); }
        .tab-btn.active { background-color: var(--gris-claro); color: var(--verde-oscuro); border-top: 3px solid var(--verde-oscuro); }
        
        /* Contenido de las Pestañas */
        .tab-content { display: none; padding: 20px; }
        .tab-content.active { display: block; }
        
        /* Tarjetas de Dashboard */
        .dashboard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 20px; }
        .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); border-left: 5px solid var(--verde-militar); }
        .card h3 { margin-top: 0; color: var(--gris-oscuro); }
        .card.alert { border-left-color: var(--alerta-roja); }
        
        /* Tablas */
        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        th { background-color: var(--verde-militar); color: white; }
    </style>
</head>
<body>

    <header>
        <h1>Tablero de Comando - C2 Regimiento</h1>
        <div id="usuario-activo">Usuario: <strong>Jefe de Regimiento (Admin)</strong></div>
    </header>

    <div class="tabs">
        <button class="tab-btn active" onclick="openTab(event, 'Jefe')">Jefatura</button>
        <button class="tab-btn" onclick="openTab(event, 'SegundoJefe')">2do Jefe</button>
        <button class="tab-btn" onclick="openTab(event, 'S1')">S1 (Personal)</button>
        <button class="tab-btn" onclick="openTab(event, 'S2')">S2 (Inteligencia)</button>
        <button class="tab-btn" onclick="openTab(event, 'S3')">S3 (Operaciones)</button>
        <button class="tab-btn" onclick="openTab(event, 'S4')">S4 (Logística)</button>
    </div>

    <div id="Jefe" class="tab-content active">
        <h2>Visión Global (Nivel Estratégico)</h2>
        <p>Resumen automatizado de las 4 áreas de conducción.</p>
        <div class="dashboard-grid">
            <div class="card">
                <h3>Estado de Fuerza</h3>
                <h1 style="color: var(--verde-militar); font-size: 40px; margin: 10px 0;">92%</h1>
                <p>Efectivos Presentes. 8% en Licencia/Sanidad.</p>
            </div>
            <div class="card">
                <h3>Disponibilidad Operativa</h3>
                <p><strong>Vehículos (S4):</strong> 15/20 Operativos</p>
                <p><strong>Munición (S4):</strong> Nivel Óptimo</p>
                <p><strong>Nivel Instrucción (S3):</strong> Etapa Subunidad</p>
            </div>
            <div class="card alert">
                <h3>Novedades de Trascendencia</h3>
                <p>🔴 1x Vehículo Unimog fuera de servicio (Falla motor).</p>
                <p>🟡 Alerta meteorológica: Fuertes vientos zona de polígono.</p>
            </div>
        </div>
    </div>

    <div id="SegundoJefe" class="tab-content">
        <h2>Supervisión y Ejecución (Nivel Coordinación)</h2>
        <div class="dashboard-grid">
            <div class="card">
                <h3>Servicios de Guardia</h3>
                <p>Oficial de Servicio: Tte 1ro GOMEZ</p>
                <p>Estado de Puestos: Cubiertos y sin novedades.</p>
            </div>
            <div class="card">
                <h3>Justicia y Disciplina</h3>
                <p>Sanciones en trámite: 2</p>
                <p>Actuaciones por Accidente: 0</p>
            </div>
        </div>
    </div>

    <div id="S1" class="tab-content">
        <h2>S1 - Personal</h2>
        <button style="padding: 10px; background: var(--verde-militar); color: white; border: none; border-radius: 5px; cursor: pointer;">+ Cargar Parte Diario</button>
        <table>
            <tr>
                <th>Subunidad</th>
                <th>Presentes</th>
                <th>Licencia</th>
                <th>Sanidad</th>
                <th>En Cambio de Cuerpo</th>
            </tr>
            <tr><td>Ca Ite A</td><td>85</td><td>5</td><td>2</td><td>1</td></tr>
            <tr><td>Ca Ite B</td><td>82</td><td>8</td><td>1</td><td>0</td></tr>
            <tr><td>Ca Cdo y Ser</td><td>105</td><td>10</td><td>3</td><td>2</td></tr>
        </table>
    </div>

    <div id="S2" class="tab-content">
        <h2>S2 - Inteligencia y Seguridad</h2>
        <div class="card">
            <h3>Apreciación de Situación Local</h3>
            <p><strong>Clima:</strong> Despejado, 22°C. Ideal para instrucción en el terreno.</p>
            <p><strong>Tránsito/Rutas:</strong> Circulación normal en Caminos de las Sierras. Accesos a la guarnición despejados.</p>
            <p><strong>Seguridad de Instalaciones:</strong> Controles de acceso perimetral reforzados.</p>
        </div>
    </div>

    <div id="S3" class="tab-content">
        <h2>S3 - Operaciones e Instrucción</h2>
        <div class="card">
            <h3>Calendario de Actividades</h3>
            <ul>
                <li><strong>Hoy, 0800hs:</strong> Tiro de combate (Ca Ite A). Polígono de la Guarnición.</li>
                <li><strong>Mañana, 1400hs:</strong> Planeamiento Táctico Urbano (Jefes de Sección).</li>
            </ul>
        </div>
    </div>

    <div id="S4" class="tab-content">
        <h2>S4 - Logística</h2>
        <table>
            <tr>
                <th>Clase</th>
                <th>Rubro</th>
                <th>Estado</th>
                <th>Observaciones</th>
            </tr>
            <tr><td>I</td><td>Racionamiento</td><td>🟢 Óptimo</td><td>Raciones calientes aseguradas por 15 días.</td></tr>
            <tr><td>III</td><td>Combustible</td><td>🟡 Medio</td><td>Solicitando reabastecimiento de gasoil.</td></tr>
            <tr><td>V</td><td>Munición</td><td>🟢 Óptimo</td><td>Aprobado para tiro de Ca Ite A.</td></tr>
        </table>
    </div>

    <script>
        function openTab(evt, tabName) {
            var i, tabcontent, tablinks;
            tabcontent = document.getElementsByClassName("tab-content");
            for (i = 0; i < tabcontent.length; i++) {
                tabcontent[i].style.display = "none";
            }
            tablinks = document.getElementsByClassName("tab-btn");
            for (i = 0; i < tablinks.length; i++) {
                tablinks[i].className = tablinks[i].className.replace(" active", "");
            }
            document.getElementById(tabName).style.display = "block";
            evt.currentTarget.className += " active";
        }
    </script>
</body>
</html>
